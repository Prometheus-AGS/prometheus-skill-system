{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/shared/scripts/detect-project-context.sh 2>&1 || true",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/shared/scripts/guard-direct-deploy.sh 2>&1",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/validate-state.sh 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/shared/scripts/validate-gitops-write.sh 2>&1 || true",
            "timeout": 10000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "assessor",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/state-checkpoint.sh \"${EVOLUTION_NAME:-default}\" assess phase_complete 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/workflow-dispatch.sh \"${EVOLUTION_NAME:-default}\" phase_complete assess 2>&1 || true"
          }
        ]
      },
      {
        "matcher": "analyst",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/state-checkpoint.sh \"${EVOLUTION_NAME:-default}\" analyze phase_complete 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/workflow-dispatch.sh \"${EVOLUTION_NAME:-default}\" phase_complete analyze 2>&1 || true"
          }
        ]
      },
      {
        "matcher": "planner",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/state-checkpoint.sh \"${EVOLUTION_NAME:-default}\" plan phase_complete 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/workflow-dispatch.sh \"${EVOLUTION_NAME:-default}\" phase_complete plan 2>&1 || true"
          }
        ]
      },
      {
        "matcher": "executor",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/validate-state.sh 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/state-checkpoint.sh \"${EVOLUTION_NAME:-default}\" execute phase_complete 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/workflow-dispatch.sh \"${EVOLUTION_NAME:-default}\" phase_complete execute 2>&1 || true"
          }
        ]
      },
      {
        "matcher": "reflector",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/log-reflection.sh 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/state-checkpoint.sh \"${EVOLUTION_NAME:-default}\" reflect phase_complete 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/workflow-dispatch.sh \"${EVOLUTION_NAME:-default}\" phase_complete reflect 2>&1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/state-finalize.sh \"${EVOLUTION_NAME:-default}\" 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/workflow-dispatch.sh \"${EVOLUTION_NAME:-default}\" cycle_complete 2>&1 || true"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/process/iterative-evolver/scripts/finalize-session.sh 2>&1 || true"
          }
        ]
      }
    ]
  }
}
