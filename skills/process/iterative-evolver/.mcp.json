{
  "mcpServers": {
    "sycophancy-correction": {
      "command": "sycophancy-correction",
      "description": "Detect and correct sycophantic patterns in reflect and assess outputs"
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "@anthropic/tavily-mcp@latest"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@anthropic/sequential-thinking-mcp@latest"]
    }
  }
}
