{
  "lifecycle": {
    "on_activate": "scripts/state-init.sh",
    "on_detect_orchestrator": "scripts/detect-orchestrators.sh"
  },
  "triggers": {
    "file_patterns": [
      "**/useEntityCRUD.ts",
      "**/EntityTable.tsx",
      "**/EntitySheets.tsx",
      "**/columns.tsx"
    ],
    "keywords": [
      "useEntityCRUD",
      "useEntityView",
      "registerSchema",
      "entity graph",
      "EntityTable",
      "EntityFormSheet",
      "@prometheus-ags/prometheus-entity-management",
      "cascadeInvalidation"
    ]
  }
}
